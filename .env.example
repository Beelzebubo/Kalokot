# Justice_system — Environment Example
# Copy to .env and fill in your values
# cp .env.example .env

# LLM Provider (pick one)
# Gemini (recommended for structured output)
GEMINI_API_KEY=
# Anthropic Claude
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# OpenRouter (alternative to Anthropic/OpenAI)
OPENROUTER_API_KEY=
# Microsoft Phi (local model — no API key required, runs via transformers)
# PHI_API_KEY=

# Text-to-Speech — now using browser-native Web Speech API (free, no API key needed)
# The /tts server endpoint is disabled; TTS happens client-side via speechSynthesis
# ELEVENLABS_API_KEY is no longer required

# Server
API_PORT=8000
API_HOST=127.0.0.1
# PRODUCTION=1  # Disables /docs and /redoc endpoints
# ALLOWED_ORIGINS=http://localhost:8080,https://your-netlify-site.netlify.app  # CORS origins
# PORT=8000  # Used by Railway/Fly.io (overrides API_PORT when set)

# Legal Knowledge Base
LEGAL_DIR=docs/legal

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/justice.log
